# Copy this file to ".env" and adjust values for your machine.
# .env holds secrets/config and is git-ignored (NEVER commit it).

# PostgreSQL connection string.
# Format: postgresql+psycopg://USER:PASSWORD@HOST:PORT/DATABASE
# On a default macOS Homebrew / Postgres.app install, your Mac username is the
# DB user and there is usually no password. Adjust if yours differs.
DATABASE_URL=postgresql+psycopg://amitsingh@localhost:5432/incident_manager

APP_NAME=Enterprise AI Incident Manager

# Secret used to sign JWTs. Generate a strong one with:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# AI / LLM (local Ollama). Change LLM_MODEL to swap models.
LLM_MODEL=llama3.1:8b
LLM_TEMPERATURE=0.2
OLLAMA_HOST=http://localhost:11434
